<Window x:Class="Fenestra.Sample.BuilderStyle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Builder Style Sample" Height="500" Width="600">
    <StackPanel Margin="20" HorizontalAlignment="Center">
        <TextBlock Text="Fenestra - Builder Style (Program.cs)"
                   HorizontalAlignment="Center"
                   FontSize="20" Margin="0,0,0,20" />

        <!-- Tray Icon -->
        <GroupBox Header="System Tray" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <Button Content="Show Tray Icon" Click="OnShowTray" Margin="0,0,0,5" />
                <Button Content="Hide Tray Icon" Click="OnHideTray" Margin="0,0,0,5" />
                <Button Content="Show Balloon Tip" Click="OnShowBalloon" />
            </StackPanel>
        </GroupBox>

        <!-- Taskbar Progress -->
        <GroupBox Header="Taskbar Progress" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="0"
                        ValueChanged="OnProgressChanged" Margin="0,0,0,5" />
                <WrapPanel HorizontalAlignment="Center">
                    <Button Content="Normal" Click="OnProgressNormal" Margin="0,0,5,0" />
                    <Button Content="Paused" Click="OnProgressPaused" Margin="0,0,5,0" />
                    <Button Content="Error" Click="OnProgressError" Margin="0,0,5,0" />
                    <Button Content="Indeterminate" Click="OnProgressIndeterminate" Margin="0,0,5,0" />
                    <Button Content="Clear" Click="OnProgressClear" />
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Dialogs -->
        <GroupBox Header="Dialogs" Margin="0,0,0,10">
            <WrapPanel Margin="10" HorizontalAlignment="Center">
                <Button Content="Open File" Click="OnOpenFile" Margin="0,0,5,5" />
                <Button Content="Save File" Click="OnSaveFile" Margin="0,0,5,5" />
                <Button Content="Open Folder" Click="OnOpenFolder" Margin="0,0,5,5" />
                <Button Content="Message" Click="OnShowMessage" Margin="0,0,5,5" />
            </WrapPanel>
        </GroupBox>

        <!-- Credential Vault -->
        <GroupBox Header="Credential Vault" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Button Content="Store (string)" Click="OnCredStoreString" Margin="0,0,5,0" />
                    <Button Content="Read (string)" Click="OnCredReadString" Margin="0,0,5,0" />
                    <Button Content="Store (bytes)" Click="OnCredStoreBytes" Margin="0,0,5,0" />
                    <Button Content="Read (bytes)" Click="OnCredReadBytes" Margin="0,0,5,0" />
                    <Button Content="List" Click="OnCredList" Margin="0,0,5,0" />
                    <Button Content="Delete All" Click="OnCredDeleteAll" />
                </WrapPanel>
                <TextBlock Text="Open Control Panel → Credential Manager → Windows Credentials to see entries prefixed with the app id."
                           TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" FontSize="11" />
            </StackPanel>
        </GroupBox>

        <!-- Idle Detection -->
        <GroupBox Header="Idle Detection" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock x:Name="IdleStatusText" Text="Status: active" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock x:Name="IdleTimeText" Text="Idle time: 0s" HorizontalAlignment="Center" Foreground="Gray" />
                <TextBlock Text="Threshold: 10s. Stop touching mouse/keyboard for 10s to see the status flip."
                           TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" FontSize="11" Margin="0,5,0,0" />
            </StackPanel>
        </GroupBox>

        <!-- App Lifecycle -->
        <GroupBox Header="App Lifecycle" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock x:Name="LifecycleFirstRunText" />
                <TextBlock x:Name="LifecycleVersionText" />
                <TextBlock x:Name="LifecyclePrevVersionText" />
                <TextBlock x:Name="LifecycleInstallDateText" />
                <TextBlock x:Name="LifecycleLaunchCountText" />
                <TextBlock Text="Close and reopen to see LaunchCount increment. Delete HKCU\SOFTWARE\Fenestra.Sample.BuilderStyle\Lifecycle to reset."
                           TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" FontSize="11" Margin="0,5,0,0" />
            </StackPanel>
        </GroupBox>

        <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0,10,0,0" Foreground="Gray" />
    </StackPanel>
</Window>
