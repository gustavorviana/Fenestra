<Window x:Class="Fenestra.Sample.AppStyle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fenestra — All Features Sample" Height="600" Width="560">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="10" Margin="0">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#555" />
        </Border>

        <TabControl Margin="10">
            <!-- General -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Ctrl+Shift+F to restore window from anywhere"
                                   Foreground="Gray" FontSize="11" Margin="0,0,0,15" />

                        <GroupBox Header="System Tray" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Show Tray Icon" Click="OnShowTray" Margin="0,0,0,4" />
                                <Button Content="Show Balloon Notification" Click="OnShowBalloon" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Taskbar Progress" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Simulate Progress (0–100%)" Click="OnSimulateProgress" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Dialogs" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Open File" Click="OnOpenFile" Margin="0,0,0,4" />
                                <Button Content="Save File" Click="OnSaveFile" Margin="0,0,0,4" />
                                <Button Content="Show Message (Yes/No)" Click="OnShowMessage" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Auto-Start" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Check Auto-Start Status" Click="OnCheckAutoStart" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Toast Notifications -->
            <TabItem Header="Toast Notifications">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <!-- Basic -->
                        <GroupBox Header="Basic Toast" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Title:" Margin="0,0,0,2" />
                                <TextBox x:Name="ToastTitle" Text="Hello from Fenestra" Margin="0,0,0,6" />
                                <TextBlock Text="Body:" Margin="0,0,0,2" />
                                <TextBox x:Name="ToastBody" Text="This is a toast notification!" Margin="0,0,0,6" />
                                <TextBlock Text="Attribution:" Margin="0,0,0,2" />
                                <TextBox x:Name="ToastAttribution" Text="" Margin="0,0,0,6" />
                                <Button Content="Show Toast" Click="OnShowToast" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Scenario & Duration -->
                        <GroupBox Header="Scenario &amp; Duration" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Scenario:" VerticalAlignment="Center" Width="70" />
                                    <ComboBox x:Name="ToastScenarioCombo" Width="150" SelectedIndex="0">
                                        <ComboBoxItem Content="Default" />
                                        <ComboBoxItem Content="Reminder" />
                                        <ComboBoxItem Content="Alarm" />
                                        <ComboBoxItem Content="IncomingCall" />
                                        <ComboBoxItem Content="Urgent" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Duration:" VerticalAlignment="Center" Width="70" />
                                    <ComboBox x:Name="ToastDurationCombo" Width="150" SelectedIndex="0">
                                        <ComboBoxItem Content="Short" />
                                        <ComboBoxItem Content="Long" />
                                    </ComboBox>
                                </StackPanel>
                                <Button Content="Show with Scenario" Click="OnShowToastWithScenario" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Buttons -->
                        <GroupBox Header="With Buttons" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Toast with Action Buttons" Click="OnShowToastWithButtons" Margin="0,0,0,4" />
                                <Button Content="Toast with Text Input" Click="OnShowToastWithInput" Margin="0,0,0,4" />
                                <Button Content="Toast with Dropdown" Click="OnShowToastWithDropdown" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Images -->
                        <GroupBox Header="Images" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Image path (file:///):" Margin="0,0,0,2" />
                                <TextBox x:Name="ToastImagePath" Text="" Margin="0,0,0,6" />
                                <Button Content="Toast with Hero Image" Click="OnShowToastWithHero" Margin="0,0,0,4" />
                                <Button Content="Toast with App Logo" Click="OnShowToastWithLogo" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Audio -->
                        <GroupBox Header="Audio" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Sound:" VerticalAlignment="Center" Width="70" />
                                    <ComboBox x:Name="ToastAudioCombo" Width="150" SelectedIndex="0">
                                        <ComboBoxItem Content="Default" />
                                        <ComboBoxItem Content="IM" />
                                        <ComboBoxItem Content="Mail" />
                                        <ComboBoxItem Content="Reminder" />
                                        <ComboBoxItem Content="Alarm1" />
                                    </ComboBox>
                                </StackPanel>
                                <CheckBox x:Name="ToastSilentCheck" Content="Silent" Margin="0,0,0,6" />
                                <Button Content="Show with Audio" Click="OnShowToastWithAudio" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Progress -->
                        <GroupBox Header="Progress Bar" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Status:" Margin="0,0,0,2" />
                                <TextBox x:Name="ToastProgressStatus" Text="Downloading..." Margin="0,0,0,6" />
                                <TextBlock Text="Progress:" Margin="0,0,0,2" />
                                <Slider x:Name="ToastProgressSlider" Minimum="0" Maximum="100" Value="0"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        ValueChanged="OnToastProgressChanged" Margin="0,0,0,2" />
                                <TextBlock x:Name="ToastProgressLabel" Text="0%" Foreground="Gray" Margin="0,0,0,6" />
                                <Button Content="Show Progress Toast" Click="OnShowProgressToast" Margin="0,0,0,4" />
                                <Button Content="Complete &amp; Remove" Click="OnCompleteProgressToast" />
                            </StackPanel>
                        </GroupBox>

                        <!-- Management -->
                        <GroupBox Header="Management" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Clear All Notifications" Click="OnClearToastHistory" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
